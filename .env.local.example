# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL (used for redirects)
NEXT_PUBLIC_SITE_URL=https://aguirremoderntile.com

# Resend (email notifications for form submissions)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=Aguirre Modern Tile <noreply@aguirremoderntile.com>
CONTACT_FORM_TO_EMAIL=vin@moderntile.pro

# Google Analytics (optional - GA4 Measurement ID)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe (for sending invoices and collecting payments)
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Webhook secret: create webhook at https://dashboard.stripe.com/webhooks
# pointing to https://yourdomain.com/api/stripe/webhook
# Events to listen for: invoice.paid, invoice.payment_failed, invoice.overdue
STRIPE_WEBHOOK_SECRET=whsec_...
